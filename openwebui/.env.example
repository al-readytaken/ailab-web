# Ollama API URL (internal docker network; overrides the image default of /ollama)
# Open WebUI internal port
WEBUI_PORT=3001
WEBUI_URL="https://openwebui-local"
CORS_ALLOW_ORIGIN="https://openwebui-local"
WEBUI_SECRET_KEY="your-secret-key-must-be-at-least-32-characters-long"
OLLAMA_BASE_URL="http://ollama:11434"
HF_TOKEN=""

# Root password for SSH access
ROOT_PASSWORD=set-your-password-here

