# SWAG domain and certificate configuration
#
# Development mode (STAGING=true):
#   Uses a self-signed certificate (10-year validity, regenerated on recreate).
#   certbot is skipped. Works with any URL, including the default placeholder.
#
# Production mode (STAGING=false):
#   Let's Encrypt certificate issued via certbot (90-day, auto-renewed).
#   Requires URL set to your real domain and proper VALIDATION/EMAIL config.
URL=openwebui-local
SUBDOMAINS=www
VALIDATION=http
EMAIL=admin@example.com
STAGING=true
